# ═══════════════════════════════════════════════════════════════════════════
# ERP_Web — Variables de Entorno (ejemplo)
# ═══════════════════════════════════════════════════════════════════════════
# Copiá este archivo como `.env` (backend) o `.env.local` (frontend) y
# completá los valores reales. NUNCA commitees los archivos `.env` reales.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Backend ────────────────────────────────────────────────────────────────
# Supabase Postgres — copiar desde Project Settings → Database → Connection string (Session mode, puerto 5432)
DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD@db.PROYECTO.supabase.co:5432/postgres?ssl=require

# Supabase URLs y keys
SUPABASE_URL=https://PROYECTO.supabase.co
SUPABASE_KEY=eyJ...service_role_key   # Service role — NUNCA exponer al cliente

# JWT — generar nuevo con: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=cambiar_por_secret_aleatorio_largo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Gemini API (OCR + chatbot)
GEMINI_API_KEY=AIza...

# CORS — dominio del frontend en Vercel
CORS_ORIGINS=["https://erp-web.vercel.app","http://localhost:3000"]

# Email transaccional (reset password, invitaciones)
RESEND_API_KEY=re_xxx
EMAIL_FROM=erp@tudominio.com

# URL pública del frontend (para construir links en emails)
APP_URL=https://erp-web.vercel.app

# App
APP_NAME=ERP Universal
VERSION=5.0.0
DEBUG=False


# ─── Frontend (Next.js) ─────────────────────────────────────────────────────
# Estas variables van en `frontend/.env.local`
# (las que empiezan con NEXT_PUBLIC_ se exponen al cliente — no poner secrets)

NEXT_PUBLIC_API_URL=https://erp-web-backend.up.railway.app
NEXT_PUBLIC_SUPABASE_URL=https://PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_key   # Anon key (público), NO el service role
